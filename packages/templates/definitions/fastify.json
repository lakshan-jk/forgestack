{
  "id": "fastify",
  "name": "Fastify",
  "description": "Fastify 5 server with autoloaded plugins/routes, env validation, structured logging, security middleware, health checks and graceful shutdown.",
  "category": "core",
  "required": true,
  "tags": ["fastify", "http", "server"],
  "dependsOn": ["typescript"],
  "files": [
    { "path": ".gitignore", "template": "fastify/gitignore.hbs" },
    { "path": "README.md", "template": "fastify/readme.md.hbs" },
    { "path": "src/server.ts", "template": "fastify/src/server.ts.hbs" },
    { "path": "src/app.ts", "template": "fastify/src/app.ts.hbs" },
    { "path": "src/config/env.ts", "template": "fastify/src/config/env.ts.hbs" },
    { "path": "src/plugins/security.ts", "template": "fastify/src/plugins/security.ts.hbs" },
    { "path": "src/modules/health/health.route.ts", "template": "fastify/src/modules/health/health.route.ts.hbs" }
  ],
  "packageJson": {
    "dependencies": {
      "fastify": "^5.2.0",
      "fastify-plugin": "^5.0.1",
      "@fastify/autoload": "^6.0.3",
      "@fastify/cors": "^10.0.1",
      "@fastify/helmet": "^12.0.1",
      "@fastify/rate-limit": "^10.2.0",
      "pino": "^9.5.0",
      "zod": "^3.24.1"
    },
    "devDependencies": {
      "pino-pretty": "^13.0.0"
    },
    "scripts": {
      "dev": "tsx watch src/server.ts",
      "start": "node dist/server.js"
    },
    "extra": {}
  },
  "env": [
    { "key": "NODE_ENV", "description": "Runtime environment", "type": "string", "required": false, "default": "development" },
    { "key": "HOST", "description": "Interface to bind", "type": "string", "required": false, "default": "0.0.0.0" },
    { "key": "PORT", "description": "HTTP port", "type": "port", "required": false, "default": "3000", "example": "3000" },
    { "key": "LOG_LEVEL", "description": "Pino log level", "type": "string", "required": false, "default": "info" },
    { "key": "CORS_ORIGIN", "description": "Comma-separated allowed origins", "type": "string", "required": false, "default": "*" },
    { "key": "RATE_LIMIT_MAX", "description": "Max requests per window per IP", "type": "number", "required": false, "default": "100" }
  ],
  "notes": [
    "Plugins in `src/plugins` and `*.route.ts` files in `src/modules` are auto-loaded — drop a file in and it wires itself.",
    "Health checks: GET /health (liveness) and GET /ready (readiness)."
  ]
}

:root {
  color-scheme: dark;
  font-family: system-ui, sans-serif;
}

body {
  margin: 0;
  background: #0b0a1f;
  color: #f4f5f7;
}

.app {
  max-width: 640px;
  margin: 0 auto;
  padding: 64px 24px;
}

button {
  margin-top: 16px;
  padding: 8px 16px;
  border-radius: 8px;
  border: 1px solid #333;
  background: #1a1830;
  color: inherit;
  cursor: pointer;
}

import { randomUUID } from 'node:crypto';
import type { FastifyInstance } from 'fastify';
import { z } from 'zod';
import { qdrant } from '../../lib/qdrant.js';
import { chat, embed } from '../../lib/ollama.js';
import { chunkText } from '../../lib/chunk.js';
import { env } from '../../config/env.js';

const ingestBody = z.object({
  text: z.string().min(1),
  source: z.string().optional(),
});

const queryBody = z.object({
  question: z.string().min(1),
  topK: z.number().int().min(1).max(10).optional(),
});

/**
 * Retrieval-Augmented Generation.
 *   POST /rag/ingest  chunk → embed → upsert into Qdrant
 *   POST /rag/query   embed question → search → generate a grounded answer
 */
export default async function ragRoute(app: FastifyInstance): Promise<void> {
  app.post('/rag/ingest', async (request, reply) => {
    const { text, source } = ingestBody.parse(request.body);
    const chunks = chunkText(text);

    const points = await Promise.all(
      chunks.map(async (chunk) => ({
        id: randomUUID(),
        vector: await embed(chunk),
        payload: { text: chunk, source: source ?? 'unknown' },
      })),
    );

    await qdrant.upsert(env.QDRANT_COLLECTION, { wait: true, points });
    return reply.code(202).send({ ingested: points.length });
  });

  app.post('/rag/query', async (request) => {
    const { question, topK } = queryBody.parse(request.body);

    const vector = await embed(question);
    const matches = await qdrant.search(env.QDRANT_COLLECTION, {
      vector,
      limit: topK ?? 4,
      with_payload: true,
    });

    const context = matches
      .map((m) => (m.payload?.text as string | undefined) ?? '')
      .filter(Boolean)
      .join('\n\n');

    const answer = await chat([
      {
        role: 'system',
        content:
          'Answer the question using only the provided context. If the context is insufficient, say you do not know.',
      },
      { role: 'user', content: `Context:\n${context}\n\nQuestion: ${question}` },
    ]);

    return {
      answer,
      sources: matches.map((m) => m.payload?.source ?? 'unknown'),
    };
  });
}

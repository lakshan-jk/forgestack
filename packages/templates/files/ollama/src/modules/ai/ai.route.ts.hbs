import type { FastifyInstance } from 'fastify';
import { z } from 'zod';
import { chat, type ChatMessage } from '../../lib/ollama.js';

const chatBody = z.object({
  message: z.string().min(1),
  system: z.string().optional(),
});

/** Simple chat endpoint backed by a local Ollama model. */
export default async function aiRoute(app: FastifyInstance): Promise<void> {
  app.post('/ai/chat', async (request) => {
    const { message, system } = chatBody.parse(request.body);
    const messages: ChatMessage[] = [];
    if (system) messages.push({ role: 'system', content: system });
    messages.push({ role: 'user', content: message });
    const reply = await chat(messages);
    return { reply };
  });
}

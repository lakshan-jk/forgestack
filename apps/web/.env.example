# Auth.js session encryption secret.
# Generate one with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=replace-with-a-32-byte-base64-secret

# ForgeStack control-plane API base URL.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Admin account — the ONLY email allowed to view usage metrics.
ADMIN_EMAIL=you@example.com
# Set a password to enable the admin login (hashed at runtime; keep in .env.local).
ADMIN_PASSWORD=
# Shared secret the metrics dashboard uses to read the API's /api/metrics.
# Must match the API's METRICS_TOKEN. Generate: openssl rand -hex 24
METRICS_TOKEN=

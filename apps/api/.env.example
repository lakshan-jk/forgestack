# ForgeStack control-plane API
NODE_ENV=development
HOST=0.0.0.0
PORT=4000

# Comma-separated list of allowed origins for CORS (the web app).
CORS_ORIGIN=http://localhost:3100

# Log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# --- AI Stack Advisor ---
# Embeddings provider: local (offline, no key) | huggingface (hosted) | fake (instant, tests)
EMBEDDINGS_PROVIDER=local
# Local Transformers.js model (downloaded & cached on first use)
LOCAL_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
# Hosted HuggingFace Inference (only if EMBEDDINGS_PROVIDER=huggingface)
HF_TOKEN=
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Vector store: memory (default) | atlas (MongoDB Atlas Vector Search — Phase D)
VECTOR_STORE=memory

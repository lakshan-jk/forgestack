# ForgeStack control-plane API
NODE_ENV=development
HOST=0.0.0.0
PORT=4000

# Comma-separated list of allowed origins for CORS (the web app).
CORS_ORIGIN=http://localhost:3100

# Log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# --- AI Stack Advisor ---
# Embeddings provider: local (offline, no key) | huggingface (hosted) | fake (instant, tests)
EMBEDDINGS_PROVIDER=local
# Local Transformers.js model (downloaded & cached on first use)
LOCAL_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
# Hosted HuggingFace Inference (only if EMBEDDINGS_PROVIDER=huggingface)
HF_TOKEN=
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Vector store: memory (default, zero-config) | atlas (MongoDB Atlas Vector Search)
VECTOR_STORE=memory
# Only needed when VECTOR_STORE=atlas — see docs/ai-advisor.md
MONGODB_ATLAS_URI=
ATLAS_DB=forgestack
ATLAS_COLLECTION=module_embeddings
ATLAS_VECTOR_INDEX=module_vector_index
# Must match your embedding model's output dims (MiniLM = 384)
EMBEDDING_DIMENSIONS=384

# --- Anonymous telemetry (opt-out) ---
# Disable entirely: FORGESTACK_TELEMETRY_DISABLED=1
FORGESTACK_TELEMETRY_DISABLED=
# Collector URL (defaults to this instance's own /api/telemetry)
TELEMETRY_ENDPOINT=
# Shared secret to read GET /api/metrics. When set, the endpoint requires it.
# Must match the web app's METRICS_TOKEN. Generate: openssl rand -hex 24
METRICS_TOKEN=

# --- Persistence (metrics store) ---
# SQLite by default. For Postgres: set provider="postgresql" in prisma/schema.prisma
# and use postgresql://user:pass@host:5432/db
DATABASE_URL=file:./forgestack.db
